# ============================================
# Math-Change - Ejemplo de Configuración
# ============================================
# Copia este archivo a .env y completa los valores
# ============================================

# --- POSTGRESQL ---
# Formato: postgresql+asyncpg://USUARIO:PASSWORD@HOST:PUERTO/DB_NAME
DATABASE_URL=postgresql+asyncpg://sumas_user:tu_password_seguro@base_postgres_general:5432/sumas_restas

# --- S3/MINIO STORAGE ---
S3_ACCESS_KEY=tu_minio_access_key
S3_SECRET_KEY=tu_minio_secret_key
S3_ENDPOINT_URL=http://minio:9000
S3_BUCKET_NAME=suma-resta
S3_REGION=us-east-1

# --- SEGURIDAD (JWT) ---
# Genera una clave segura para producción
SECRET_KEY=cambiame_por_una_clave_aleatoria_y_larga

# --- FRONTEND ---
VITE_API_URL=http://localhost:8000

# --- CORS ---
ALLOWED_ORIGINS=*
ENABLE_SECURITY_HEADERS=false
